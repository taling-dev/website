---
/**
 * ClientMarquee — A looping horizontal scroll of client logos.
 * Uses CSS animation for a seamless, zero-JS marquee effect.
 */
import { 
  Cpu, 
  Layers, 
  Shield, 
  Zap, 
  Cloud, 
  Monitor, 
  Globe, 
  Activity, 
  Briefcase,
  Database
} from 'lucide-astro';

const clients = [
  { name: 'TechFlow', Icon: Cpu },
  { name: 'StackUp', Icon: Layers },
  { name: 'Securely', Icon: Shield },
  { name: 'Flash', Icon: Zap },
  { name: 'SkyNet', Icon: Cloud },
  { name: 'Vision', Icon: Monitor },
  { name: 'Global', Icon: Globe },
  { name: 'Pulse', Icon: Activity },
  { name: 'BizCore', Icon: Briefcase },
  { name: 'DataBox', Icon: Database },
];
---

<section class="py-12 md:py-16 lg:py-20 overflow-hidden bg-white/50 border-y border-brand-light w-screen relative left-1/2 -translate-x-1/2">
  <div class="px-6 md:px-12 lg:px-24 mb-8 md:mb-10 text-center">
    <p class="text-sm md:text-base font-semibold uppercase tracking-widest text-brand-text/60">
      Trusted by industry leaders
    </p>
  </div>

  <div class="relative flex overflow-hidden group">
    <!-- First marquee container -->
    <div class="flex animate-marquee whitespace-nowrap gap-12 md:gap-24 items-center shrink-0 min-w-full justify-around pr-12 md:pr-24">
      {clients.map(({ name, Icon }) => (
        <div class="flex items-center gap-3 grayscale opacity-40 hover:grayscale-0 hover:opacity-100 transition-all duration-300 group/item">
          <Icon class="w-8 h-8 md:w-10 md:h-10 text-brand-purple group-hover/item:scale-110 transition-transform" />
          <span class="text-xl md:text-2xl font-bold tracking-tight text-[#131B2E]">{name}</span>
        </div>
      ))}
    </div>
    
    <!-- Second marquee container (exact duplicate for seamless loop) -->
    <div class="flex animate-marquee whitespace-nowrap gap-12 md:gap-24 items-center shrink-0 min-w-full justify-around pr-12 md:pr-24" aria-hidden="true">
      {clients.map(({ name, Icon }) => (
        <div class="flex items-center gap-3 grayscale opacity-40 hover:grayscale-0 hover:opacity-100 transition-all duration-300 group/item">
          <Icon class="w-8 h-8 md:w-10 md:h-10 text-brand-purple group-hover/item:scale-110 transition-transform" />
          <span class="text-xl md:text-2xl font-bold tracking-tight text-[#131B2E]">{name}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .animate-marquee {
    will-change: transform;
    /* We animate to -100% because we have two containers and we want them to cycle perfectly */
  }
</style>
