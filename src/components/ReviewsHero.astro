---
/**
 * ReviewsHero — Hero section for the Reviews page.
 * Pill badge + large heading + supporting paragraph.
 * Matches Figma node 142:489.
 */
import { Star } from 'lucide-astro';
---

<section class="px-6 md:px-12 lg:px-24 pt-12 md:pt-16 lg:pt-20 flex flex-col items-center text-center gap-6 md:gap-8 max-w-[1000px] mx-auto">

  <!-- Badge pill -->
  <div class="inline-flex items-center gap-2 bg-[#EBEEFF] rounded-full px-5 py-2 w-fit">
    <Star class="w-4 h-4 text-brand-crimson fill-brand-crimson" />
    <span class="text-[12px] md:text-[14px] font-bold tracking-[0.06em] uppercase text-brand-crimson">
      Client Success Stories
    </span>
  </div>

  <!-- Heading -->
  <h1 class="text-4xl lg:text-5xl font-extrabold text-[#131B2E] leading-tight">
    Community Impact
  </h1>

  <!-- Subtext -->
  <p class="text-base md:text-lg lg:text-xl font-medium text-brand-text leading-relaxed max-w-3xl">
    Lorem ipsum dolor sit amet, consectetur adipiscing elit. Nunc cursus metus ac ipsum volutpat sollicitudin.
  </p>

</section>
