---
// Bottom bento row — testimonial + CTA
---

<section class="grid grid-cols-1 md:grid-cols-2 gap-3 px-4 md:px-6 pb-4 md:pb-6">

  <!-- Left — Testimonial card -->
  <div class="relative bg-white rounded-2xl p-6 overflow-hidden flex flex-col gap-3 hover:shadow-md transition-shadow">
    <!-- Star rating -->
    <div class="flex items-center gap-1">
      {Array(5).fill(0).map((_, i) => (
        <svg class={`w-4 h-4 ${i < 4 ? 'text-yellow-400' : 'text-yellow-200'}`} fill="currentColor" viewBox="0 0 20 20">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
        </svg>
      ))}
    </div>

    <h3 class="font-semibold text-gray-800 text-base">What our clients say</h3>

    <blockquote class="border-l-2 border-gray-200 pl-3">
      <p class="text-gray-500 text-sm leading-relaxed">
        "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Nunc cursus metus ac ipsum volutpat sollicitudin. Maecenas a leo euismod, egestas nunc at, porta odio."
      </p>
    </blockquote>

    <p class="text-xs font-bold text-gray-700 tracking-wide uppercase">Andi, CEO Kogu Space</p>

    <!-- Large watermark number -->
    <div class="absolute -bottom-4 right-4 text-8xl font-black text-gray-100 select-none pointer-events-none leading-none">
      4.8
    </div>
  </div>

  <!-- Right — CTA card -->
  <div class="relative bg-brand-crimson rounded-2xl p-6 flex flex-col items-center justify-center gap-3 text-center overflow-hidden hover:brightness-105 transition-all cursor-pointer group">
    <!-- Background glow -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-64 h-32 bg-white/10 rounded-full blur-3xl"></div>

    <!-- Play icon -->
    <div class="w-12 h-12 rounded-full border-2 border-white/50 flex items-center justify-center group-hover:scale-110 transition-transform">
      <svg class="w-5 h-5 text-white ml-0.5" fill="currentColor" viewBox="0 0 24 24">
        <path d="M8 5v14l11-7z"/>
      </svg>
    </div>

    <div class="relative z-10">
      <h3 class="text-xl font-bold text-white mb-1">Digitalize your business now!</h3>
      <p class="text-pink-200 text-sm mb-4">Let's build something great together.</p>
      <a
        href="#"
        class="inline-flex items-center gap-1.5 border border-white/60 text-white text-xs font-semibold px-4 py-2 rounded-full hover:bg-white hover:text-brand-crimson transition-all"
      >
        GET IN TOUCH
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
        </svg>
      </a>
    </div>
  </div>

</section>
