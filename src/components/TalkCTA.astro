---
/**
 * TalkCTA - Bottom CTA section on the contact page.
 * Matches Figma node 232:117.
 */
import { Phone } from "lucide-astro";
---

<section class="max-w-[1728px] mx-auto px-6 md:px-12 lg:px-24 pb-20">
  <div
    class="w-full bg-gradient-to-r from-white via-[#F7EDFF] to-[#F0DBFF] rounded-[20px] p-8 md:p-12 lg:p-14 flex flex-col items-center gap-6 md:gap-8 text-center"
  >
    <h2 class="text-2xl md:text-3xl lg:text-4xl font-extrabold text-[#131B2E]">
      Have Project in Mind? Let's Talk
    </h2>

    <a
      href="tel:+62888333222"
      class="bg-gradient-to-r from-[#BD185D] to-[#7E22CE] text-white rounded-full px-7 md:px-10 py-3.5 md:py-5 flex items-center gap-3 md:gap-4 hover:scale-105 transition-transform shadow-lg shadow-brand-purple/20"
    >
      <div class="bg-white/20 p-2 rounded-full">
        <Phone class="size-5 md:size-6" />
      </div>
      <span class="text-lg md:text-xl lg:text-2xl font-extrabold leading-none"
        >+62 888 333 222</span
      >
    </a>
  </div>
</section>
