---
/**
 * PortfolioCTA — "Check our Portfolio" call-to-action banner.
 * Gradient background with heading, subtext, and "Explore More" button.
 * Matches Figma node 249:161 (Group 74).
 */
import { ArrowRight } from 'lucide-astro';
---

<section class="px-6 md:px-10 pb-8 md:pb-10 lg:pb-12">
  <div
    class="rounded-2xl px-8 md:px-14 py-10 md:py-14 lg:py-16 flex flex-col md:flex-row items-start md:items-center justify-between gap-6 md:gap-10"
    style="background: linear-gradient(117deg, rgba(255,255,255,1) 0%, rgba(247,237,255,1) 50%, rgba(240,219,255,1) 100%);"
  >
    <!-- Text -->
    <div class="flex flex-col gap-3 max-w-2xl">
      <h2 class="text-3xl md:text-4xl lg:text-[48px] font-extrabold text-[#131B2E] leading-tight">
        Check our Portfolio
      </h2>
      <p class="text-base md:text-lg lg:text-[24px] font-medium text-brand-text leading-relaxed">
        Lorem ipsum dolor sit amet, consectetur adipiscing elit. Nunc cursus
        metus ac ipsum volutpat sollicitudin.
      </p>
    </div>

    <!-- Button -->
    <a
      href="#"
      class="inline-flex items-center gap-3 bg-gradient-to-r from-[#bd185d] to-[#7e22ce] text-white text-lg lg:text-[24px] font-extrabold tracking-[0.02em] px-8 py-4 rounded-full hover:brightness-110 hover:scale-[1.03] transition-all duration-200 whitespace-nowrap group"
    >
      Explore More
      <ArrowRight class="w-5 h-5 lg:w-6 lg:h-6 group-hover:translate-x-1 transition-transform" />
    </a>
  </div>
</section>
