---
import { Menu } from 'lucide-astro';
---

<nav class="bg-white border-b border-gray-100 sticky top-0 z-50">
  <div class="max-w-[1728px] mx-auto px-4 md:px-6 py-4 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2">
      <img src="/logo.svg" alt="Taling logo" class="h-8 md:h-9 w-auto" />
    </a>

    <!-- Nav links -->
    <ul class="hidden lg:flex items-center gap-8 text-[18px] font-medium text-brand-text">
      <li>
        <a href="#" class="text-[#b7175a] border-b-2 border-[#b7175a] pb-1">Home</a>
      </li>
      <li><a href="#" class="hover:text-brand-crimson transition-colors">Services</a></li>
      <li><a href="#" class="hover:text-brand-crimson transition-colors">About</a></li>
      <li><a href="#" class="hover:text-brand-crimson transition-colors">Reviews</a></li>
      <li><a href="#" class="hover:text-brand-crimson transition-colors">Contact</a></li>
    </ul>

    <!-- CTA -->
    <a
      href="#"
      class="hidden md:inline-flex items-center gap-2 bg-gradient-to-r from-[#bd185d] to-[#7e22ce] text-white text-[16px] lg:text-[18px] font-extrabold px-6 lg:px-8 py-2.5 lg:py-3 rounded-full hover:brightness-110 transition-all whitespace-nowrap"
    >
      Start a Project
    </a>

    <!-- Mobile hamburger -->
    <button
      id="menu-toggle"
      class="lg:hidden p-2 rounded-lg text-gray-600 hover:bg-gray-100"
      aria-label="Open menu"
    >
      <Menu class="w-6 h-6" />
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden lg:hidden bg-white border-t border-gray-100 px-6 py-6 flex flex-col gap-5 text-lg font-medium text-brand-text">
    <a href="#" class="text-brand-crimson font-semibold">Home</a>
    <a href="#">Services</a>
    <a href="#">About</a>
    <a href="#">Reviews</a>
    <a href="#">Contact</a>
    <a href="#" class="mt-2 inline-flex justify-center bg-gradient-to-r from-[#bd185d] to-[#7e22ce] text-white font-bold px-5 py-3 rounded-full">
      Start a Project
    </a>
  </div>
</nav>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
