---
import { Menu } from "lucide-astro";

const pathname = new URL(Astro.request.url).pathname;
const currentPath = pathname.slice(1); // remove the leading slash

const navLinks = [
  { href: "/", label: "Home" },
  { href: "/services", label: "Services" },
  { href: "#about", label: "About" },
  { href: "/reviews", label: "Reviews" },
  { href: "/contact", label: "Contact" },
];
---

<nav class="bg-white border-b border-gray-100 sticky top-0 z-50">
  <div
    class="max-w-[1728px] mx-auto px-6 md:px-12 lg:px-24 py-4 flex items-center justify-between"
  >
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2">
      <img src="/logo.svg" alt="Taling logo" class="h-8 md:h-9 w-auto" />
    </a>

    <!-- Nav links -->
    <ul
      class="hidden lg:flex items-center gap-8 text-[18px] font-medium text-brand-text"
    >
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class={`transition-colors hover:text-brand-crimson ${
                (link.href === "/" && currentPath === "") ||
                (link.href !== "/" && currentPath.startsWith(link.href.slice(1)) && link.href.startsWith("/"))
                  ? "text-brand-crimson font-bold border-b-2 border-brand-crimson pb-1"
                  : ""
              }`}
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <!-- CTA -->
    <a
      href="/contact"
      class="hidden md:hidden lg:inline-flex items-center gap-2 bg-gradient-to-r from-[#bd185d] to-[#7e22ce] text-white text-[16px] lg:text-[18px] font-extrabold px-6 lg:px-8 py-2.5 lg:py-3 rounded-full hover:brightness-110 transition-all whitespace-nowrap"
    >
      Start a Project
    </a>

    <!-- Mobile hamburger -->
    <button
      id="menu-toggle"
      class="lg:hidden p-2 rounded-lg text-gray-600 hover:bg-gray-100"
      aria-label="Open menu"
    >
      <Menu class="w-6 h-6" />
    </button>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden lg:hidden bg-white border-t border-gray-100 px-6 py-6 flex flex-col gap-5 text-lg font-medium text-brand-text"
  >
    {
      navLinks.map((link) => (
        <a
          href={link.href}
          class={`${
            (link.href === "/" && currentPath === "") ||
            (link.href !== "/" && currentPath.startsWith(link.href.slice(1)) && link.href.startsWith("/"))
              ? "text-brand-crimson font-semibold"
              : ""
          }`}
        >
          {link.label}
        </a>
      ))
    }
    <a
      href="/contact"
      class="mt-2 inline-flex justify-center bg-gradient-to-r from-[#bd185d] to-[#7e22ce] text-white font-bold px-5 py-3 rounded-full"
    >
      Start a Project
    </a>
  </div>
</nav>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  toggle?.addEventListener("click", () => menu?.classList.toggle("hidden"));
</script>
