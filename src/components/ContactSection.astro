---
/**
 * ContactSection - Contains the contact form and contact information.
 * Matches Figma nodes 232:63 (Form) and 232:91/232:93 (Info cards).
 */
import { Mail, MapPin, Linkedin, Instagram, Github } from "lucide-astro";
---

<section
  class="px-6 md:px-12 lg:px-24 pb-12 md:pb-16 lg:pb-20 flex flex-col lg:flex-row gap-12 lg:gap-24 items-start"
>
  <!-- Left - Contact Form -->
  <div
    class="w-full lg:w-[580px] bg-white rounded-[20px] shadow-[0px_0px_18px_-1px_rgba(0,0,0,0.08)] p-7 md:p-10 lg:p-12 flex flex-col gap-6 md:gap-8"
  >
    <h3 class="text-xl md:text-2xl font-extrabold text-[#131B2E]">
      Leave your message
    </h3>

    <form class="flex flex-col gap-5 md:gap-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5 md:gap-6">
        <div class="flex flex-col gap-2">
          <label
            for="name"
            class="text-base font-extrabold text-[#131B2E]"
            >Name</label
          >
          <input
            type="text"
            id="name"
            name="name"
            placeholder="Your Name"
            class="bg-[#F8F8FA] border-[#E9E8EB] border-[1.5px] rounded-[12px] h-[52px] px-4 text-sm md:text-base focus:outline-none focus:border-brand-purple"
          />
        </div>
        <div class="flex flex-col gap-2">
          <label
            for="email"
            class="text-base font-extrabold text-[#131B2E]"
            >Email</label
          >
          <input
            type="email"
            id="email"
            name="email"
            placeholder="Your Email"
            class="bg-[#F8F8FA] border-[#E9E8EB] border-[1.5px] rounded-[12px] h-[52px] px-4 text-sm md:text-base focus:outline-none focus:border-brand-purple"
          />
        </div>
      </div>

      <div class="flex flex-col gap-2">
        <label
          for="subject"
          class="text-base font-extrabold text-[#131B2E]"
          >Subject</label
        >
        <input
          type="text"
          id="subject"
          name="subject"
          placeholder="Subject"
          class="bg-[#F8F8FA] border-[#E9E8EB] border-[1.5px] rounded-[12px] h-[52px] px-4 text-sm md:text-base focus:outline-none focus:border-brand-purple"
        />
      </div>

      <div class="flex flex-col gap-2">
        <label
          for="message"
          class="text-base font-extrabold text-[#131B2E]"
          >Message</label
        >
        <textarea
          id="message"
          name="message"
          rows="4"
          placeholder="Your Message"
          class="bg-[#F8F8FA] border-[#E9E8EB] border-[1.5px] rounded-[12px] p-4 text-sm md:text-base focus:outline-none focus:border-brand-purple resize-none"
        ></textarea>
      </div>

      <div class="flex items-center gap-3">
        <input
          type="checkbox"
          id="privacy"
          class="w-4 h-4 rounded-full border-[#E9E8EB] checked:bg-brand-crimson focus:ring-brand-purple cursor-pointer"
        />
        <label
          for="privacy"
          class="text-[13px] md:text-sm font-medium text-[#9D9D9D]"
        >
          I agree to the <a href="/privacy" class="text-[#6B9ED5] underline"
            >privacy policy</a
          >
        </label>
      </div>

      <button
        type="submit"
        class="w-full md:w-[180px] bg-gradient-to-r from-[#BD185D] to-[#7E22CE] text-white text-base md:text-lg font-extrabold h-[46px] rounded-full hover:brightness-110 transition-all flex items-center justify-center"
      >
        Send Message
      </button>
    </form>
  </div>

  <!-- Right - Contact Info & Social -->
  <div class="w-full lg:flex-1 flex flex-col gap-8 md:gap-10">
    <div class="flex flex-col gap-5 md:gap-6">
      <h2
        class="text-3xl lg:text-4xl font-extrabold text-[#131B2E] leading-tight max-w-[500px]"
      >
        Don’t hesitate to contact us
      </h2>

      <!-- Contact Cards -->
      <div class="flex flex-col gap-4">
        <!-- Email -->
        <div
          class="bg-white rounded-[20px] shadow-[0px_0px_18px_-1px_rgba(0,0,0,0.08)] p-6 md:p-7 flex items-center gap-5"
        >
          <div
            class="size-[44px] bg-[#BC185C]/10 rounded-full flex items-center justify-center text-brand-crimson shrink-0"
          >
            <Mail class="size-5" />
          </div>
          <div class="flex flex-col">
            <span class="text-base md:text-lg font-extrabold text-[#131B2E]"
              >Email</span
            >
            <span
              class="text-base md:text-lg font-medium text-[#595959] tracking-tight"
              >devtaling@gmail.com</span
            >
          </div>
        </div>

        <!-- Location -->
        <div
          class="bg-white rounded-[20px] shadow-[0px_0px_18px_-1px_rgba(0,0,0,0.08)] p-6 md:p-7 flex items-center gap-5"
        >
          <div
            class="size-[44px] bg-[#7E22CE]/10 rounded-full flex items-center justify-center text-brand-purple shrink-0"
          >
            <MapPin class="size-5" />
          </div>
          <div class="flex flex-col">
            <span class="text-base md:text-lg font-extrabold text-[#131B2E]"
              >Location</span
            >
            <span
              class="text-base md:text-lg font-medium text-[#595959] tracking-tight"
              >Jl. Raya ITS, Surabaya</span
            >
          </div>
        </div>
      </div>
    </div>

    <!-- Social Media -->
    <div class="flex flex-col gap-5">
      <h3 class="text-xl md:text-2xl font-extrabold text-[#131B2E]">
        Social Media:
      </h3>
      <div class="flex items-center gap-5">
        <a
          href="#"
          class="text-[#131B2E] hover:text-brand-crimson transition-colors"
        >
          <Linkedin class="size-6 md:size-8" />
        </a>
        <a
          href="#"
          class="text-[#131B2E] hover:text-brand-crimson transition-colors"
        >
          <Instagram class="size-6 md:size-8" />
        </a>
        <a
          href="#"
          class="text-[#131B2E] hover:text-brand-crimson transition-colors"
        >
          <Github class="size-6 md:size-8" />
        </a>
      </div>
    </div>
  </div>
</section>
