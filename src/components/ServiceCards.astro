---
/**
 * ServiceCards — Three service offering cards.
 * Left/Right are white with a light shadow, centre card is dark (#0F172A).
 * Matches Figma nodes Group 65, 66, 67.
 */
import { Globe, LayoutGrid, Monitor } from 'lucide-astro';
---

<section class="px-6 md:px-10 py-8 md:py-10 lg:py-12">
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 lg:gap-6">

    <!-- Card 1 — Logo, Graphic Design, & Web Design -->
    <div
      class="relative bg-white rounded-2xl p-7 lg:p-8 flex flex-col gap-5
             shadow-[0px_0px_18px_-1px_rgba(0,0,0,0.08)]
             hover:shadow-lg hover:-translate-y-1 transition-all duration-300
             group"
    >
      <!-- Icon box -->
      <div class="w-[53px] h-[50px] rounded-[10px] bg-brand-light flex items-center justify-center">
        <Globe class="w-[28px] h-[28px] text-brand-crimson" />
      </div>

      <!-- Number -->
      <span class="text-[18px] font-semibold text-brand-crimson">01</span>

      <!-- Title -->
      <h3 class="text-xl md:text-[24px] font-semibold text-black leading-snug">
        Logo, Graphic Design, &amp; Web Design
      </h3>

      <!-- Description -->
      <p class="text-base md:text-lg lg:text-[24px] font-medium text-brand-text leading-relaxed">
        Lorem ipsum dolor sit amet, consectetur adipiscing elit. Nunc cursus
        metus ac ipsum volutpat sollicitudin.
      </p>
    </div>

    <!-- Card 2 — Custom Websites & Web Apps (DARK) -->
    <div
      class="relative bg-[#0F172A] rounded-2xl p-7 lg:p-8 flex flex-col gap-5
             hover:shadow-lg hover:-translate-y-1 transition-all duration-300
             group"
    >
      <!-- Icon box -->
      <div class="w-[53px] h-[50px] rounded-[10px] bg-[#283044] flex items-center justify-center">
        <LayoutGrid class="w-[24px] h-[24px] text-brand-crimson" />
      </div>

      <!-- Number -->
      <span class="text-[18px] font-semibold text-[#B08BCF]">02</span>

      <!-- Title -->
      <h3 class="text-xl md:text-[24px] font-semibold text-white leading-snug">
        Custom Websites &amp; Web Apps
      </h3>

      <!-- Description -->
      <p class="text-base md:text-lg lg:text-[24px] font-medium text-[#D0D2D5] leading-relaxed">
        Lorem ipsum dolor sit amet, consectetur adipiscing elit. Nunc cursus
        metus ac ipsum volutpat sollicitudin.
      </p>
    </div>

    <!-- Card 3 — Custom Business Dashboards -->
    <div
      class="relative bg-white rounded-2xl p-7 lg:p-8 flex flex-col gap-5
             shadow-[0px_0px_18px_-1px_rgba(0,0,0,0.08)]
             hover:shadow-lg hover:-translate-y-1 transition-all duration-300
             group md:col-span-2 lg:col-span-1"
    >
      <!-- Icon box -->
      <div class="w-[53px] h-[50px] rounded-[10px] bg-brand-light flex items-center justify-center">
        <Monitor class="w-[28px] h-[28px] text-brand-crimson" />
      </div>

      <!-- Number -->
      <span class="text-[18px] font-semibold text-brand-crimson">03</span>

      <!-- Title -->
      <h3 class="text-xl md:text-[24px] font-semibold text-black leading-snug">
        Custom Business Dashboards
      </h3>

      <!-- Description -->
      <p class="text-base md:text-lg lg:text-[24px] font-medium text-brand-text leading-relaxed">
        Lorem ipsum dolor sit amet, consectetur adipiscing elit. Nunc cursus
        metus ac ipsum volutpat sollicitudin.
      </p>
    </div>

  </div>
</section>
