---
import Navbar from '../components/Navbar.astro';
import HeroBento from '../components/HeroBento.astro';
import BottomBento from '../components/BottomBento.astro';
import Footer from '../components/Footer.astro';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>Taling — Digital Agency</title>
    <meta name="description" content="Taling helps businesses digitalize through custom websites, web apps, and business dashboards. Let's build something great together." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@200;300;400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>

  <!--
    Desktop: allow scrolling if content overflows
    Max-width container to match Figma and prevent infinite stretching
  -->
  <body class="bg-brand-bg font-sans overflow-x-hidden min-h-screen flex flex-col">
    <Navbar />
    <main class="flex-1 max-w-[1728px] mx-auto w-full flex flex-col">
      <HeroBento />
      <BottomBento />
    </main>
    <Footer />
  </body>
</html>