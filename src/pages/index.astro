---
import Navbar from '../components/Navbar.astro';
import HeroBento from '../components/HeroBento.astro';
import BottomBento from '../components/BottomBento.astro';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>Taling — Digital Agency</title>
    <meta name="description" content="Taling helps businesses digitalize through custom websites, web apps, and business dashboards. Let's build something great together." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  </head>

  <!--
    Desktop: full viewport height, no scroll (overflow-hidden)
    Mobile:  allow vertical scroll (overflow-auto via md:overflow-hidden)
  -->
  <body class="bg-gray-50 font-sans overflow-x-hidden overflow-y-auto md:overflow-hidden">
    <div class="flex flex-col md:h-screen bg-gray-50 gap-3">
      <Navbar />
      <HeroBento />
      <BottomBento />
    </div>
  </body>
</html>