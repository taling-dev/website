---
import Navbar from '../components/Navbar.astro';
import ContactHero from '../components/ContactHero.astro';
import ContactSection from '../components/ContactSection.astro';
import TalkCTA from '../components/TalkCTA.astro';
import Footer from '../components/Footer.astro';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>Contact Us — Taling Dev</title>
    <meta name="description" content="Get in touch with Taling Dev. Let's transform your business with custom digital solutions." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@200;300;400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>

  <body class="bg-brand-bg font-sans overflow-x-hidden min-h-screen flex flex-col">
    <Navbar />

    <main class="flex-1 max-w-[1728px] mx-auto w-full flex flex-col">
      <ContactHero />
      <ContactSection />
      <TalkCTA />
    </main>

    <Footer />
  </body>
</html>
