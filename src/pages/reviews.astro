---
import Navbar from '../components/Navbar.astro';
import ReviewsHero from '../components/ReviewsHero.astro';
import ReviewGrid from '../components/ReviewGrid.astro';
import ClientMarquee from '../components/ClientMarquee.astro';
import ModernizeCTA from '../components/ModernizeCTA.astro';
import Footer from '../components/Footer.astro';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>Reviews — Taling Dev</title>
    <meta name="description" content="See what our clients say about Taling Dev. We deliver high-impact digital solutions that drive business success." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@200;300;400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>

  <body class="bg-[#FAF7FF] font-sans overflow-x-hidden min-h-screen flex flex-col">
    <Navbar />

    <main class="flex-1 max-w-[1728px] mx-auto w-full flex flex-col">
      <ReviewsHero />
      <ReviewGrid />
      <ClientMarquee />
      <ModernizeCTA />
    </main>

    <Footer />
  </body>
</html>
